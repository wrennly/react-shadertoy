{
  "name": "react-shadertoy",
  "version": "0.11.0",
  "description": "Run GLSL shaders in React — Shadertoy compatible, AI-friendly. Paste raw GLSL and it just works.",
  "author": "Wrennly (https://github.com/wrennly)",
  "license": "MIT",
  "homepage": "https://github.com/wrennly/react-shadertoy",
  "repository": {
    "type": "git",
    "url": "https://github.com/wrennly/react-shadertoy"
  },
  "keywords": [
    "react",
    "shadertoy",
    "glsl",
    "webgl",
    "webgl2",
    "shader",
    "fragment-shader",
    "creative-coding",
    "generative-art",
    "multipass",
    "ai-friendly"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react --external react-dom --clean",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
